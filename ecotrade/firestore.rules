rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      // Admin can update roles
      allow update: if request.auth != null
                    && (request.auth.uid == uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']));
    }

    // ── Seller Applications ───────────────────────────────────────────
    match /seller_applications/{uid} {
      // Buyer: bisa buat & baca milik sendiri
      allow read:   if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      // Admin: bisa baca semua dan update status
      allow read, update: if request.auth != null
                          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // ── Products ──────────────────────────────────────────────────────
    match /products/{document=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Seller Registrations (legacy) ─────────────────────────────────
    match /seller_registrations/{document=**} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    // ── Carts ──────────────────────────────────────────────────────────
    // Each buyer has their own cart document with an 'items' subcollection.
    // Only the authenticated owner can read/write their own cart.
    match /carts/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /items/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Orders ─────────────────────────────────────────────────────────
    // Buyers can create orders for themselves and read their own orders.
    // Admins can read and update order status.
    match /orders/{orderId} {
      allow create: if request.auth != null
                    && request.resource.data.buyerId == request.auth.uid;
      allow read:   if request.auth != null
                    && (resource.data.buyerId == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']));
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // ── Fallback: authenticated users ─────────────────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}