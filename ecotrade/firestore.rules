rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      // Admin can update roles
      allow update: if request.auth != null
                    && (request.auth.uid == uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']));
    }

    // ── Courier Applications ──────────────────────────────────────────
    match /courier_applications/{uid} {
      // Kurir: bisa baca & update dokumen milik sendiri (untuk toggle isActive)
      allow read:   if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
                    && (request.auth.uid == uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']));
      // Admin: bisa baca semua aplikasi kurir
      allow read:   if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // ── Seller Applications ───────────────────────────────────────────
    match /seller_applications/{uid} {
      // Buyer: bisa buat & baca milik sendiri
      allow read:   if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      // Admin: bisa baca semua dan update status
      allow read, update: if request.auth != null
                          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // ── Products ──────────────────────────────────────────────────────
    match /products/{document=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Seller Registrations (legacy) ─────────────────────────────────
    match /seller_registrations/{document=**} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    // ── Carts ──────────────────────────────────────────────────────────
    // Each buyer has their own cart document with an 'items' subcollection.
    // Only the authenticated owner can read/write their own cart.
    match /carts/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /items/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Orders ─────────────────────────────────────────────────────────
    // Buyers  : buat order milik sendiri; baca milik sendiri
    // Sellers : baca & update (confirm/assign) order milik tokonya
    // Couriers: baca & update status (picked_up/delivered) tugas miliknya
    // Admins  : baca & update semua
    match /orders/{orderId} {
      allow create: if request.auth != null
                    && request.resource.data.buyerId == request.auth.uid;

      allow read: if request.auth != null
                  && (resource.data.buyerId   == request.auth.uid
                      || resource.data.sellerId  == request.auth.uid
                      || resource.data.courierId == request.auth.uid
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']));

      allow update: if request.auth != null
                    && (resource.data.sellerId  == request.auth.uid
                        || resource.data.courierId == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']));
    }

    // ── Fallback: authenticated users ─────────────────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}